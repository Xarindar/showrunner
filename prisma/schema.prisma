generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum MediaDriver {
  REPO
  R2
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE_PACKAGE
}

enum CouponType {
  PERCENT
  FIXED
}

enum CartStatus {
  OPEN
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  DRAFT
  PENDING
  PAID
  FULFILLED
  CANCELED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  SHOPIFY
  SQUARE
  WOOCOMMERCE
}

enum MessageChannel {
  EMAIL
  SMS
}

enum MessageTemplatePurpose {
  BOOKING_CONFIRMATION
  BOOKING_REMINDER
  ORDER_RECEIPT
  INVOICE_NOTICE
  FORM_SUBMISSION
  GALLERY_ACCESS
  PASSWORD_MAGIC_LINK
  ADMIN_DIGEST
  MARKETING
  GENERAL
}

enum MessageLogStatus {
  DRAFT
  QUEUED
  SENT
  FAILED
  SUPPRESSED
}

enum EmailSendingDomainStatus {
  PENDING
  VERIFIED
  FAILED
}

enum EmailCheckStatus {
  UNKNOWN
  PASS
  FAIL
}

enum EmailSuppressionScope {
  MARKETING
  TRANSACTIONAL
  ALL
}

enum EmailCategory {
  TRANSACTIONAL
  ADMIN
  MARKETING
}

enum EmailOutboxStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  SUPPRESSED
  CANCELED
}

enum EmailProviderEventType {
  ACCEPTED
  DELIVERED
  DELIVERY_DELAYED
  BOUNCED
  COMPLAINED
  OPENED
  CLICKED
  UNSUBSCRIBED
}

enum EmailSubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  PENDING
  BOUNCED
}

enum EmailListMembershipStatus {
  ACTIVE
  UNSUBSCRIBED
  PENDING
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELED
}

enum BillingDocumentType {
  INVOICE
  QUOTE
  CONTRACT
}

enum BillingDocumentStatus {
  DRAFT
  SENT
  ACCEPTED
  PAID
  VOID
  OVERDUE
}

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum AutomationTrigger {
  BOOKING_CREATED
  BOOKING_CANCELED
  ORDER_PAID
  FORM_SUBMITTED
  GALLERY_APPROVED
  CLIENT_TAGGED
  INVOICE_OVERDUE
  MANUAL
}

enum AutomationAction {
  SEND_EMAIL
  NOTIFY_ADMIN
  CREATE_INVOICE
  REQUEST_REVIEW
  SEND_WEBHOOK
}

enum AutomationRunStatus {
  QUEUED
  SUCCEEDED
  FAILED
  SKIPPED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

enum FormStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FormFieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  SELECT
  CHECKBOX
  RADIO
  DATE
  SIGNATURE
  HIDDEN
}

enum FormFieldRole {
  NONE
  SUBMITTER_NAME
  SUBMITTER_EMAIL
}

enum FormDestination {
  STANDALONE_LEAD
  CLIENT
  BOOKING
  ORDER
  GALLERY
  INQUIRY
}

enum TestimonialStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum PortfolioGalleryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PortfolioGalleryVisibility {
  PUBLIC
  PRIVATE
  PASSWORD
}

enum PortfolioItemType {
  IMAGE
  VIDEO
  FILE
}

enum PortfolioAccessStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AnalyticsEventType {
  BOOKING_STARTED
  BOOKING_COMPLETED
  LEAD_SUBMITTED
  GALLERY_VIEWED
  FAVORITE_ADDED
  VIEW_ITEM
  ADD_TO_CART
  BEGIN_CHECKOUT
  PURCHASE
  REFUND
  INVOICE_PAID
  CUSTOM
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id              String      @id @default("site")
  businessName    String      @default("Showrunner")
  contactEmail    String      @default("admin@example.com")
  timezone        String      @default("America/Chicago")
  themePreset     String      @default("clean")
  themePrimary    String      @default("#116466")
  heroImageUrl    String      @default("/hero.svg")
  heroHeadline    String      @default("Book services without the back-and-forth")
  heroSubheadline String      @default("A client-ready website and admin panel for service appointments.")
  introTitle      String      @default("A calm, capable client site")
  introBody       String      @default("Update the headline, hero image, core copy, services, hours, and bookings from one protected admin area.")
  mediaDriver     MediaDriver @default(REPO)
  enabledModules  Json
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Service {
  id                  String    @id @default(cuid())
  slug                String    @unique @default(cuid())
  name                String
  description         String?
  durationMinutes     Int
  location            String?
  bufferBeforeMinutes Int       @default(0)
  bufferAfterMinutes  Int       @default(0)
  minimumNoticeHours  Int       @default(12)
  maxAdvanceDays      Int       @default(60)
  slotIntervalMinutes Int       @default(30)
  intakePrompt        String?
  policyText          String?
  requirePolicy       Boolean   @default(false)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  bookings            Booking[]
}

model AvailabilityRule {
  id           String   @id @default(cuid())
  weekday      Int
  startMinutes Int
  endMinutes   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BlockedTime {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())
}

model Booking {
  id                 String        @id @default(cuid())
  serviceId          String
  service            Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  clientId           String?
  client             Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerName       String
  customerEmail      String
  customerPhone      String?
  notes              String?
  intakeResponse     String?
  policyAccepted     Boolean       @default(false)
  adminNotes         String?
  cancellationReason String?
  startsAt           DateTime
  endsAt             DateTime
  status             BookingStatus @default(PENDING)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([startsAt, endsAt])
  @@index([serviceId, startsAt])
  @@index([clientId])
}

model MediaAsset {
  id        String      @id @default(cuid())
  driver    MediaDriver
  key       String
  url       String
  filename  String
  alt       String?
  createdAt DateTime    @default(now())
}

model Client {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  phone            String?
  status           String            @default("active")
  privateNotes     String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bookings         Booking[]
  notes            ClientNote[]
  carts            Cart[]
  orders           Order[]
  formSubmissions  FormSubmission[]
  testimonials     Testimonial[]
  billingDocuments BillingDocument[]
  messageLogs      MessageLog[]
  emailSubscribers EmailSubscriber[]
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([clientId])
}

model Product {
  id                  String              @id @default(cuid())
  slug                String              @unique @default(cuid())
  name                String
  summary             String              @default("")
  description         String              @default("")
  type                ProductType         @default(PHYSICAL)
  status              ProductStatus       @default(DRAFT)
  basePriceCents      Int                 @default(0)
  compareAtPriceCents Int?
  currency            String              @default("USD")
  sku                 String?
  imageUrl            String              @default("")
  tags                Json                @default("[]")
  attributes          Json                @default("{}")
  trackInventory      Boolean             @default(false)
  inventoryQuantity   Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  variants            ProductVariant[]
  collectionProducts  CollectionProduct[]
  cartItems           CartItem[]
  orderItems          OrderItem[]

  @@index([status])
  @@index([type])
}

model ProductVariant {
  id                  String      @id @default(cuid())
  productId           String
  product             Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name                String
  sku                 String?
  optionName          String      @default("")
  optionValue         String      @default("")
  priceCents          Int?
  compareAtPriceCents Int?
  trackInventory      Boolean     @default(false)
  inventoryQuantity   Int?
  isDefault           Boolean     @default(false)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  cartItems           CartItem[]
  orderItems          OrderItem[]

  @@index([productId])
  @@index([isActive])
}

model Collection {
  id                 String              @id @default(cuid())
  slug               String              @unique @default(cuid())
  name               String
  description        String              @default("")
  status             ProductStatus       @default(DRAFT)
  isFeatured         Boolean             @default(false)
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  collectionProducts CollectionProduct[]

  @@index([status])
  @@index([isFeatured])
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([collectionId, productId])
  @@index([productId])
}

model Coupon {
  id              String     @id @default(cuid())
  code            String     @unique
  type            CouponType
  amountCents     Int?
  percentOff      Int?
  startsAt        DateTime?
  endsAt          DateTime?
  maxRedemptions  Int?
  redemptionCount Int        @default(0)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  carts           Cart[]
  orders          Order[]

  @@index([isActive])
}

model Cart {
  id            String     @id @default(cuid())
  clientId      String?
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerEmail String?
  status        CartStatus @default(OPEN)
  currency      String     @default("USD")
  subtotalCents Int        @default(0)
  discountCents Int        @default(0)
  totalCents    Int        @default(0)
  couponId      String?
  coupon        Coupon?    @relation(fields: [couponId], references: [id], onDelete: SetNull)
  checkoutUrl   String?
  expiresAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  items         CartItem[]

  @@index([clientId])
  @@index([status])
}

model CartItem {
  id             String          @id @default(cuid())
  cartId         String
  cart           Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity       Int             @default(1)
  unitPriceCents Int
  lineTotalCents Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerName  String
  customerEmail String
  status        OrderStatus @default(PENDING)
  currency      String      @default("USD")
  subtotalCents Int         @default(0)
  discountCents Int         @default(0)
  taxCents      Int         @default(0)
  shippingCents Int         @default(0)
  totalCents    Int         @default(0)
  couponId      String?
  coupon        Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  notes         String      @default("")
  checkoutUrl   String?
  placedAt      DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  payments      Payment[]

  @@index([clientId])
  @@index([status])
  @@index([customerEmail])
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  name           String
  sku            String?
  quantity       Int             @default(1)
  unitPriceCents Int
  lineTotalCents Int
  createdAt      DateTime        @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Payment {
  id                      String          @id @default(cuid())
  orderId                 String
  order                   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider                PaymentProvider
  status                  PaymentStatus   @default(PENDING)
  amountCents             Int
  currency                String          @default("USD")
  externalPaymentId       String?
  externalCheckoutSession String?
  hostedReceiptUrl        String?
  rawSummary              Json            @default("{}")
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([orderId])
  @@index([provider])
  @@index([status])
}

model MessageTemplate {
  id               String                 @id @default(cuid())
  key              String?                @unique
  name             String
  description      String                 @default("")
  purpose          MessageTemplatePurpose @default(GENERAL)
  channel          MessageChannel         @default(EMAIL)
  subject          String                 @default("")
  previewText      String                 @default("")
  body             String
  htmlBody         String                 @default("")
  textBody         String                 @default("")
  tokens           Json                   @default("[]")
  requiredTokens   Json                   @default("[]")
  optionalTokens   Json                   @default("[]")
  version          Int                    @default(1)
  senderIdentityId String?
  senderIdentity   EmailSenderIdentity?   @relation(fields: [senderIdentityId], references: [id], onDelete: SetNull)
  isMarketing      Boolean                @default(false)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  logs             MessageLog[]
  outbox           EmailOutbox[]

  @@index([purpose])
  @@index([channel])
  @@index([isActive])
  @@index([senderIdentityId])
}

model MessageLog {
  id             String           @id @default(cuid())
  templateId     String?
  template       MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  channel        MessageChannel   @default(EMAIL)
  purpose        String           @default("general")
  recipientEmail String           @default("")
  recipientPhone String           @default("")
  subject        String           @default("")
  bodyPreview    String           @default("")
  status         MessageLogStatus @default(QUEUED)
  errorMessage   String           @default("")
  relatedType    String           @default("")
  relatedId      String           @default("")
  sentAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([templateId])
  @@index([clientId])
  @@index([status])
  @@index([recipientEmail])
}

model SuppressionListEntry {
  id        String                @id @default(cuid())
  email     String                @unique
  reason    String                @default("")
  source    String                @default("admin")
  scope     EmailSuppressionScope @default(MARKETING)
  createdAt DateTime              @default(now())
}

model EmailSendingDomain {
  id            String                   @id @default(cuid())
  domain        String                   @unique
  status        EmailSendingDomainStatus @default(PENDING)
  spfStatus     EmailCheckStatus         @default(UNKNOWN)
  dkimStatus    EmailCheckStatus         @default(UNKNOWN)
  dmarcStatus   EmailCheckStatus         @default(UNKNOWN)
  lastCheckedAt DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  senders       EmailSenderIdentity[]
}

model EmailSenderIdentity {
  id              String              @id @default(cuid())
  sendingDomainId String?
  sendingDomain   EmailSendingDomain? @relation(fields: [sendingDomainId], references: [id], onDelete: SetNull)
  name            String
  fromEmail       String
  replyToEmail    String              @default("")
  isDefault       Boolean             @default(false)
  isVerified      Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  templates       MessageTemplate[]
  outbox          EmailOutbox[]
  campaigns       EmailCampaign[]

  @@index([sendingDomainId])
  @@index([isDefault])
  @@index([fromEmail])
}

model EmailRecipientGroup {
  id                     String           @id @default(cuid())
  key                    String           @unique
  label                  String
  fallbackToContactEmail Boolean          @default(true)
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  recipients             EmailRecipient[]
}

model EmailRecipient {
  id        String              @id @default(cuid())
  groupId   String
  group     EmailRecipientGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email     String
  name      String              @default("")
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([groupId, email])
  @@index([email])
  @@index([isActive])
}

model EmailOutbox {
  id                String               @id @default(cuid())
  idempotencyKey    String               @unique
  templateId        String?
  template          MessageTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateKey       String               @default("")
  senderIdentityId  String?
  senderIdentity    EmailSenderIdentity? @relation(fields: [senderIdentityId], references: [id], onDelete: SetNull)
  campaignId        String?
  campaign          EmailCampaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  subscriberId      String?
  subscriber        EmailSubscriber?     @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  recipientEmail    String
  recipientName     String               @default("")
  fromName          String
  fromEmail         String
  replyToEmail      String               @default("")
  subject           String
  previewText       String               @default("")
  htmlBody          String
  textBody          String
  headers           Json                 @default("{}")
  purpose           String               @default("general")
  category          EmailCategory        @default(TRANSACTIONAL)
  relatedType       String               @default("")
  relatedId         String               @default("")
  status            EmailOutboxStatus    @default(QUEUED)
  attemptCount      Int                  @default(0)
  nextAttemptAt     DateTime             @default(now())
  lastError         String               @default("")
  providerMessageId String               @default("")
  sentAt            DateTime?
  deliveredAt       DateTime?
  bouncedAt         DateTime?
  complainedAt      DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  providerEvents    EmailProviderEvent[]

  @@index([templateId])
  @@index([senderIdentityId])
  @@index([campaignId])
  @@index([subscriberId])
  @@index([status, nextAttemptAt])
  @@index([recipientEmail])
  @@index([providerMessageId])
  @@index([relatedType, relatedId])
}

model EmailProviderEvent {
  id                String                 @id @default(cuid())
  eventKey          String                 @unique
  outboxId          String?
  outbox            EmailOutbox?           @relation(fields: [outboxId], references: [id], onDelete: SetNull)
  providerMessageId String                 @default("")
  eventType         EmailProviderEventType
  providerPayload   Json                   @default("{}")
  createdAt         DateTime               @default(now())

  @@index([outboxId])
  @@index([providerMessageId])
  @@index([eventType])
}

model EmailSubscriptionList {
  id          String                @id @default(cuid())
  name        String
  description String                @default("")
  isDefault   Boolean               @default(false)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  memberships EmailListMembership[]

  @@index([isDefault])
}

model EmailSubscriber {
  id               String                @id @default(cuid())
  email            String                @unique
  name             String                @default("")
  clientId         String?
  client           Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  status           EmailSubscriberStatus @default(ACTIVE)
  consentSource    String                @default("")
  consentedAt      DateTime?
  unsubscribedAt   DateTime?
  unsubscribeToken String                @unique
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  memberships      EmailListMembership[]
  outbox           EmailOutbox[]

  @@index([clientId])
  @@index([status])
}

model EmailListMembership {
  id           String                    @id @default(cuid())
  subscriberId String
  subscriber   EmailSubscriber           @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  listId       String
  list         EmailSubscriptionList     @relation(fields: [listId], references: [id], onDelete: Cascade)
  status       EmailListMembershipStatus @default(ACTIVE)
  joinedAt     DateTime                  @default(now())
  leftAt       DateTime?

  @@unique([subscriberId, listId])
  @@index([listId])
  @@index([status])
}

model EmailCampaign {
  id                    String               @id @default(cuid())
  name                  String
  subject               String
  previewText           String               @default("")
  htmlBody              String
  textBody              String
  senderIdentityId      String?
  senderIdentity        EmailSenderIdentity? @relation(fields: [senderIdentityId], references: [id], onDelete: SetNull)
  status                EmailCampaignStatus  @default(DRAFT)
  scheduledAt           DateTime?
  sentAt                DateTime?
  targetListIds         Json                 @default("[]")
  postalAddressSnapshot String               @default("")
  queuedCount           Int                  @default(0)
  sentCount             Int                  @default(0)
  failedCount           Int                  @default(0)
  suppressedCount       Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  outbox                EmailOutbox[]

  @@index([senderIdentityId])
  @@index([status])
}

model BillingDocument {
  id             String                @id @default(cuid())
  documentNumber String                @unique
  type           BillingDocumentType   @default(INVOICE)
  status         BillingDocumentStatus @default(DRAFT)
  clientId       String?
  client         Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerName   String
  customerEmail  String
  currency       String                @default("USD")
  subtotalCents  Int                   @default(0)
  discountCents  Int                   @default(0)
  taxCents       Int                   @default(0)
  totalCents     Int                   @default(0)
  dueAt          DateTime?
  acceptedAt     DateTime?
  paidAt         DateTime?
  notes          String                @default("")
  publicMemo     String                @default("")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  lineItems      BillingLineItem[]
  attachments    BillingAttachment[]

  @@index([clientId])
  @@index([type, status])
  @@index([customerEmail])
}

model BillingLineItem {
  id                String          @id @default(cuid())
  billingDocumentId String
  billingDocument   BillingDocument @relation(fields: [billingDocumentId], references: [id], onDelete: Cascade)
  description       String
  quantity          Int             @default(1)
  unitPriceCents    Int
  lineTotalCents    Int
  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())

  @@index([billingDocumentId])
}

model BillingAttachment {
  id                String          @id @default(cuid())
  billingDocumentId String
  billingDocument   BillingDocument @relation(fields: [billingDocumentId], references: [id], onDelete: Cascade)
  title             String
  url               String
  notes             String          @default("")
  createdAt         DateTime        @default(now())

  @@index([billingDocumentId])
}

model Automation {
  id              String            @id @default(cuid())
  name            String
  status          AutomationStatus  @default(DRAFT)
  trigger         AutomationTrigger @default(MANUAL)
  action          AutomationAction  @default(NOTIFY_ADMIN)
  targetEmail     String?
  webhookUrl      String?
  subjectTemplate String            @default("")
  bodyTemplate    String            @default("")
  conditions      Json              @default("{}")
  lastRunAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  runs            AutomationRun[]

  @@index([status])
  @@index([trigger])
}

model AutomationRun {
  id           String              @id @default(cuid())
  automationId String
  automation   Automation          @relation(fields: [automationId], references: [id], onDelete: Cascade)
  status       AutomationRunStatus @default(QUEUED)
  triggerKey   String              @default("")
  relatedType  String              @default("")
  relatedId    String              @default("")
  summary      String              @default("")
  createdAt    DateTime            @default(now())

  @@index([automationId])
  @@index([status])
}

model WebhookEndpoint {
  id            String            @id @default(cuid())
  name          String
  url           String
  signingSecret String            @default("")
  status        AutomationStatus  @default(DRAFT)
  events        Json              @default("[]")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deliveries    WebhookDelivery[]

  @@index([status])
}

model WebhookDelivery {
  id                String                @id @default(cuid())
  webhookEndpointId String
  webhookEndpoint   WebhookEndpoint       @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)
  event             String
  payload           Json                  @default("{}")
  status            WebhookDeliveryStatus @default(PENDING)
  statusCode        Int?
  errorMessage      String                @default("")
  deliveredAt       DateTime?
  createdAt         DateTime              @default(now())

  @@index([webhookEndpointId])
  @@index([status])
}

model Form {
  id                String           @id @default(cuid())
  slug              String           @unique @default(cuid())
  name              String
  description       String           @default("")
  status            FormStatus       @default(DRAFT)
  destination       FormDestination  @default(STANDALONE_LEAD)
  submitButtonLabel String           @default("Submit")
  successMessage    String           @default("Thanks. Your form was submitted.")
  notificationEmail String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  fields            FormField[]
  submissions       FormSubmission[]

  @@index([status])
  @@index([destination])
}

model FormField {
  id          String        @id @default(cuid())
  formId      String
  form        Form          @relation(fields: [formId], references: [id], onDelete: Cascade)
  label       String
  type        FormFieldType
  fieldRole   FormFieldRole @default(NONE)
  placeholder String        @default("")
  helpText    String        @default("")
  options     Json          @default("[]")
  isRequired  Boolean       @default(false)
  isHidden    Boolean       @default(false)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())

  @@index([formId])
  @@index([type])
  @@index([fieldRole])
}

model FormSubmission {
  id             String   @id @default(cuid())
  formId         String
  form           Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  submitterName  String   @default("")
  submitterEmail String   @default("")
  data           Json     @default("{}")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  @@index([formId])
  @@index([clientId])
  @@index([submitterEmail])
}

model PublicRateLimit {
  id          String   @id @default(cuid())
  key         String   @unique
  scope       String
  identifier  String
  count       Int      @default(0)
  windowStart DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, identifier])
  @@index([windowStart])
}

model Testimonial {
  id                String            @id @default(cuid())
  clientId          String?
  client            Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  authorName        String
  authorEmail       String            @default("")
  authorRole        String            @default("")
  quote             String
  rating            Int               @default(5)
  source            String            @default("first-party")
  sourceUrl         String            @default("")
  serviceName       String            @default("")
  productName       String            @default("")
  permissionGranted Boolean           @default(false)
  status            TestimonialStatus @default(PENDING)
  featured          Boolean           @default(false)
  submittedAt       DateTime          @default(now())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([featured])
}

model PortfolioGallery {
  id              String                     @id @default(cuid())
  slug            String                     @unique @default(cuid())
  title           String
  description     String                     @default("")
  status          PortfolioGalleryStatus     @default(DRAFT)
  visibility      PortfolioGalleryVisibility @default(PUBLIC)
  category        String                     @default("")
  coverImageUrl   String                     @default("")
  location        String                     @default("")
  shotAt          DateTime?
  seoTitle        String                     @default("")
  seoDescription  String                     @default("")
  proofingEnabled Boolean                    @default(false)
  downloadEnabled Boolean                    @default(false)
  accessCodeHash  String                     @default("")
  rightsNotes     String                     @default("")
  sortOrder       Int                        @default(0)
  publishedAt     DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  items           PortfolioGalleryItem[]
  accesses        PortfolioGalleryAccess[]
  favorites       PortfolioGalleryFavorite[]

  @@index([status])
  @@index([visibility])
  @@index([category])
  @@index([sortOrder])
}

model PortfolioGalleryItem {
  id             String                     @id @default(cuid())
  galleryId      String
  gallery        PortfolioGallery           @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  mediaAssetId   String?
  type           PortfolioItemType          @default(IMAGE)
  title          String                     @default("")
  caption        String                     @default("")
  altText        String                     @default("")
  imageUrl       String                     @default("")
  thumbnailUrl   String                     @default("")
  sortOrder      Int                        @default(0)
  isCover        Boolean                    @default(false)
  isDownloadable Boolean                    @default(false)
  isWatermarked  Boolean                    @default(false)
  licenseNotes   String                     @default("")
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  favorites      PortfolioGalleryFavorite[]

  @@index([galleryId])
  @@index([mediaAssetId])
  @@index([isCover])
}

model PortfolioGalleryAccess {
  id             String                @id @default(cuid())
  galleryId      String
  gallery        PortfolioGallery      @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  clientId       String?
  recipientEmail String
  accessToken    String                @unique
  status         PortfolioAccessStatus @default(ACTIVE)
  expiresAt      DateTime?
  lastViewedAt   DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([galleryId])
  @@index([recipientEmail])
  @@index([status])
}

model PortfolioGalleryFavorite {
  id          String               @id @default(cuid())
  galleryId   String
  gallery     PortfolioGallery     @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  itemId      String
  item        PortfolioGalleryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  clientId    String?
  viewerEmail String               @default("")
  notes       String               @default("")
  createdAt   DateTime             @default(now())

  @@index([galleryId])
  @@index([itemId])
  @@index([viewerEmail])
}

model AnalyticsEvent {
  id          String             @id @default(cuid())
  eventType   AnalyticsEventType @default(CUSTOM)
  eventName   String
  source      String             @default("")
  medium      String             @default("")
  campaign    String             @default("")
  landingPage String             @default("")
  referrer    String             @default("")
  pathname    String             @default("")
  sessionId   String             @default("")
  visitorId   String             @default("")
  clientEmail String             @default("")
  relatedType String             @default("")
  relatedId   String             @default("")
  valueCents  Int?
  currency    String             @default("USD")
  metadata    Json               @default("{}")
  occurredAt  DateTime           @default(now())
  createdAt   DateTime           @default(now())

  @@index([eventType])
  @@index([eventName])
  @@index([occurredAt])
  @@index([source])
  @@index([campaign])
  @@index([relatedType, relatedId])
}

model AnalyticsGoal {
  id               String             @id @default(cuid())
  key              String             @unique
  name             String
  eventType        AnalyticsEventType @default(CUSTOM)
  eventName        String             @default("")
  targetCount      Int                @default(1)
  targetValueCents Int?
  currency         String             @default("USD")
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([isActive])
  @@index([eventType])
}
