// Scheduling module models and enums.

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum BookingReminderStatus {
  CLAIMED
  QUEUED
  FAILED
}

enum BookingWaitlistStatus {
  WAITING
  PROMOTED
  DECLINED
  CANCELED
}

enum SchedulingCalendarProvider {
  GOOGLE
}

enum SchedulingCalendarOwnerType {
  SITE
  STAFF
}

enum SchedulingCalendarConnectionStatus {
  CONNECTED
  ERROR
}

model SchedulingSettings {
  id                         String   @id @default(cuid())
  siteId                     String   @unique
  site                       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  bookingReminderEnabled     Boolean  @default(true)
  bookingReminderLeadMinutes Int      @default(1440)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model SchedulingCalendarConnection {
  id                    String                             @id @default(cuid())
  siteId                String
  site                  Site                               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  provider              SchedulingCalendarProvider
  ownerType             SchedulingCalendarOwnerType
  ownerId               String                             @default("")
  calendarId            String                             @default("primary")
  displayName           String                             @default("")
  accountEmail          String                             @default("")
  status                SchedulingCalendarConnectionStatus @default(CONNECTED)
  encryptedAccessToken  String                             @default("")
  encryptedRefreshToken String                             @default("")
  scope                 String                             @default("")
  expiresAt             DateTime?
  connectedAt           DateTime?
  lastVerifiedAt        DateTime?
  lastError             String                             @default("")
  createdAt             DateTime                           @default(now())
  updatedAt             DateTime                           @updatedAt

  @@unique([siteId, provider, ownerType, ownerId])
  @@index([siteId, provider, status])
  @@index([ownerType, ownerId])
}

model Service {
  id                  String    @id @default(cuid())
  siteId              String
  site                Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  slug                String    @default(cuid())
  name                String
  description         String?
  durationMinutes     Int
  location            String?
  category            String    @default("")
  tags                Json      @default("[]")
  bufferBeforeMinutes Int       @default(0)
  bufferAfterMinutes  Int       @default(0)
  minimumNoticeHours  Int       @default(12)
  maxAdvanceDays      Int       @default(60)
  slotIntervalMinutes Int       @default(30)
  intakePrompt        String?
  policyText          String?
  requirePolicy       Boolean   @default(false)
  requestOnly         Boolean   @default(false)
  waitlistEnabled     Boolean   @default(false)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  bookings            Booking[]
  waitlistEntries     BookingWaitlistEntry[]
  staffAssignments    ServiceStaff[]
  resourceAssignments ServiceResource[]
  packageItems        ServicePackageItem[]

  @@unique([siteId, slug])
  @@index([siteId])
  @@index([siteId, category])
  @@index([siteId, isActive])
}

model ServicePackage {
  id          String               @id @default(cuid())
  siteId      String
  site        Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  slug        String               @default(cuid())
  name        String
  description String               @default("")
  tags        Json                 @default("[]")
  isActive    Boolean              @default(true)
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  items       ServicePackageItem[]

  @@unique([siteId, slug])
  @@index([siteId, isActive])
  @@index([siteId, sortOrder])
}

model ServicePackageItem {
  id        String         @id @default(cuid())
  siteId    String
  site      Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  packageId String
  package   ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  quantity  Int            @default(1)
  sortOrder Int            @default(0)
  notes     String         @default("")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([packageId, serviceId])
  @@index([siteId, serviceId])
  @@index([siteId, packageId])
}

model StaffMember {
  id                String             @id @default(cuid())
  siteId            String
  site              Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  adminUserId       String?
  adminUser         AdminUser?         @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  name              String
  email             String             @default("")
  phone             String             @default("")
  title             String             @default("")
  bio               String             @default("")
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  availabilityRules AvailabilityRule[]
  bookings          Booking[]
  waitlistEntries   BookingWaitlistEntry[]
  services          ServiceStaff[]
  portfolioGalleries PortfolioGallery[]
  mediaAssets       MediaAsset[]

  @@index([siteId, isActive])
  @@index([siteId, email])
  @@index([adminUserId])
  @@unique([siteId, adminUserId])
}

model Resource {
  id                String             @id @default(cuid())
  siteId            String
  site              Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  name              String
  type              String             @default("ROOM")
  description       String             @default("")
  location          String             @default("")
  capacity          Int                @default(1)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  availabilityRules AvailabilityRule[]
  blockouts         BlockedTime[]
  services          ServiceResource[]
  bookings          BookingResource[]

  @@index([siteId, isActive])
  @@index([siteId, type])
}

model ServiceStaff {
  id        String      @id @default(cuid())
  siteId    String
  site      Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staffId   String
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([serviceId, staffId])
  @@index([siteId, staffId])
  @@index([siteId, serviceId])
}

model ServiceResource {
  id         String   @id @default(cuid())
  siteId     String
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([serviceId, resourceId])
  @@index([siteId, resourceId])
  @@index([siteId, serviceId])
}

model AvailabilityRule {
  id           String   @id @default(cuid())
  siteId       String
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  staffId      String?
  staff        StaffMember? @relation(fields: [staffId], references: [id], onDelete: Cascade)
  resourceId   String?
  resource     Resource? @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  weekday      Int
  startMinutes Int
  endMinutes   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([siteId])
  @@index([siteId, staffId])
  @@index([siteId, resourceId])
}

model BlockedTime {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  resourceId String?
  resource  Resource? @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([siteId, startsAt, endsAt])
  @@index([siteId, resourceId])
}

model Booking {
  id                 String        @id @default(cuid())
  siteId             String
  site               Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  serviceId          String
  service            Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staffId            String?
  staff              StaffMember?  @relation(fields: [staffId], references: [id], onDelete: SetNull)
  resources          BookingResource[]
  clientId           String?
  client             Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerName       String
  customerEmail      String
  customerPhone      String?
  notes              String?
  intakeResponse     String?
  policyAccepted     Boolean       @default(false)
  adminNotes         String?
  cancellationReason String?
  startsAt           DateTime
  endsAt             DateTime
  status             BookingStatus @default(PENDING)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  reminders          BookingReminder[]
  promotedWaitlistEntries BookingWaitlistEntry[]

  @@index([siteId, startsAt, endsAt])
  @@index([serviceId, startsAt])
  @@index([staffId, startsAt])
  @@index([clientId])
}

model BookingWaitlistEntry {
  id                String                @id @default(cuid())
  siteId            String
  site              Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  serviceId         String
  service           Service               @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staffId           String?
  staff             StaffMember?          @relation(fields: [staffId], references: [id], onDelete: SetNull)
  promotedBookingId String?
  promotedBooking   Booking?              @relation(fields: [promotedBookingId], references: [id], onDelete: SetNull)
  customerName      String
  customerEmail     String
  customerPhone     String?
  notes             String?
  intakeResponse    String?
  policyAccepted    Boolean               @default(false)
  startsAt          DateTime
  status            BookingWaitlistStatus @default(WAITING)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([siteId, status, startsAt])
  @@index([serviceId, startsAt])
  @@index([staffId, startsAt])
  @@index([promotedBookingId])
}

model BookingReminder {
  id           String                @id @default(cuid())
  siteId       String
  site         Site                  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  bookingId    String
  booking      Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  leadMinutes  Int
  scheduledFor DateTime
  status       BookingReminderStatus @default(CLAIMED)
  attemptCount Int                   @default(0)
  claimedAt    DateTime?
  queuedAt     DateTime?
  failedAt     DateTime?
  lastError    String                @default("")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([bookingId])
  @@index([siteId, scheduledFor])
  @@index([siteId, status])
}

model BookingResource {
  id         String      @id @default(cuid())
  siteId     String
  site       Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  bookingId  String
  booking    Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  resourceId String
  resource   Resource    @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@unique([bookingId, resourceId])
  @@index([siteId, resourceId])
  @@index([siteId, bookingId])
}
