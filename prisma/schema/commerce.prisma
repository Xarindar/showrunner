// Products/commerce module models and enums.

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE_PACKAGE
  GIFT_CARD
}

enum CouponType {
  PERCENT
  FIXED
}

enum CartStatus {
  OPEN
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  DRAFT
  PENDING
  PAID
  FULFILLED
  CANCELED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  MANUAL
  STRIPE
  PAYPAL
  SHOPIFY
  SQUARE
  WOOCOMMERCE
}

enum PaymentGatewayConnectionStatus {
  DISCONNECTED
  PENDING
  CONNECTED
  ERROR
}

enum StripeWebhookEventStatus {
  PROCESSING
  PROCESSED
  FAILED
}

enum SquareWebhookEventStatus {
  PROCESSING
  PROCESSED
  FAILED
}

enum PayPalWebhookEventStatus {
  PROCESSING
  PROCESSED
  FAILED
}

enum GiftCardStatus {
  ACTIVE
  DISABLED
}

model Product {
  id                  String              @id @default(cuid())
  siteId              String
  site                Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  slug                String              @default(cuid())
  name                String
  summary             String              @default("")
  description         String              @default("")
  type                ProductType         @default(PHYSICAL)
  status              ProductStatus       @default(DRAFT)
  basePriceCents      Int                 @default(0)
  compareAtPriceCents Int?
  currency            String              @default("USD")
  sku                 String?
  imageUrl            String              @default("")
  tags                Json                @default("[]")
  attributes          Json                @default("{}")
  trackInventory      Boolean             @default(false)
  inventoryQuantity   Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  variants            ProductVariant[]
  collectionProducts  CollectionProduct[]
  cartItems           CartItem[]
  orderItems          OrderItem[]

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([type])
}

model ProductVariant {
  id                  String      @id @default(cuid())
  productId           String
  product             Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name                String
  sku                 String?
  optionName          String      @default("")
  optionValue         String      @default("")
  priceCents          Int?
  compareAtPriceCents Int?
  trackInventory      Boolean     @default(false)
  inventoryQuantity   Int?
  isDefault           Boolean     @default(false)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  cartItems           CartItem[]
  orderItems          OrderItem[]

  @@index([productId])
  @@index([isActive])
}

model Collection {
  id                 String              @id @default(cuid())
  siteId             String
  site               Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  slug               String              @default(cuid())
  name               String
  description        String              @default("")
  status             ProductStatus       @default(DRAFT)
  isFeatured         Boolean             @default(false)
  sortOrder          Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  collectionProducts CollectionProduct[]

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([isFeatured])
}

model CollectionProduct {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@unique([collectionId, productId])
  @@index([productId])
}

model Coupon {
  id              String     @id @default(cuid())
  siteId          String
  site            Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  code            String
  type            CouponType
  amountCents     Int?
  percentOff      Int?
  startsAt        DateTime?
  endsAt          DateTime?
  maxRedemptions  Int?
  redemptionCount Int        @default(0)
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  carts           Cart[]
  orders          Order[]

  @@unique([siteId, code])
  @@index([siteId, isActive])
}

model GiftCard {
  id                 String                 @id @default(cuid())
  siteId             String
  site               Site                   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  code               String
  status             GiftCardStatus         @default(ACTIVE)
  currency           String                 @default("USD")
  initialAmountCents Int
  balanceCents       Int
  recipientName      String                 @default("")
  recipientEmail     String                 @default("")
  purchaserName      String                 @default("")
  purchaserEmail     String                 @default("")
  note               String                 @default("")
  saleOrderItemId    String?                @unique
  saleOrderItem      OrderItem?             @relation("GiftCardSaleOrderItem", fields: [saleOrderItemId], references: [id], onDelete: SetNull)
  issuedAt           DateTime               @default(now())
  expiresAt          DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  carts              Cart[]
  orders             Order[]
  redemptions        GiftCardRedemption[]

  @@unique([siteId, code])
  @@index([siteId, status])
  @@index([recipientEmail])
}

model Cart {
  id                     String     @id @default(cuid())
  siteId                 String
  site                   Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)
  clientId               String?
  client                 Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerEmail          String?
  status                 CartStatus @default(OPEN)
  currency               String     @default("USD")
  subtotalCents          Int        @default(0)
  discountCents          Int        @default(0)
  taxCents               Int        @default(0)
  shippingCents          Int        @default(0)
  giftCardCreditCents    Int        @default(0)
  totalCents             Int        @default(0)
  couponId               String?
  coupon                 Coupon?    @relation(fields: [couponId], references: [id], onDelete: SetNull)
  giftCardId             String?
  giftCard               GiftCard?  @relation(fields: [giftCardId], references: [id], onDelete: SetNull)
  checkoutUrl            String?
  expiresAt              DateTime?
  abandonedAt            DateTime?
  recoveryEmailQueuedAt DateTime?
  recoveryAttemptCount  Int        @default(0)
  recoveryLastError     String     @default("")
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  items                  CartItem[]

  @@index([clientId])
  @@index([siteId, status])
  @@index([siteId, status, updatedAt])
}

model CartItem {
  id             String          @id @default(cuid())
  cartId         String
  cart           Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity       Int             @default(1)
  unitPriceCents Int
  lineTotalCents Int
  giftCardRecipientName String    @default("")
  giftCardRecipientEmail String   @default("")
  giftCardMessage String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model Order {
  id            String      @id @default(cuid())
  siteId        String
  site          Site        @relation(fields: [siteId], references: [id], onDelete: Cascade)
  orderNumber   String
  clientId      String?
  client        Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  customerName  String
  customerEmail String
  status        OrderStatus @default(PENDING)
  currency      String      @default("USD")
  subtotalCents Int         @default(0)
  discountCents Int         @default(0)
  taxCents      Int         @default(0)
  shippingCents Int         @default(0)
  giftCardCreditCents Int   @default(0)
  totalCents    Int         @default(0)
  couponId      String?
  coupon        Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  giftCardId    String?
  giftCard      GiftCard?   @relation(fields: [giftCardId], references: [id], onDelete: SetNull)
  notes         String      @default("")
  checkoutUrl   String?
  placedAt      DateTime?
  fulfilledAt   DateTime?
  fulfillmentCarrier String @default("")
  fulfillmentTrackingNumber String @default("")
  fulfillmentExportedAt DateTime?
  fulfillmentExportBatch String @default("")
  printLabName String @default("")
  printLabReference String @default("")
  printLabHandoffAt DateTime?
  printLabNotes String @default("")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  payments      Payment[]
  giftCardRedemptions GiftCardRedemption[]

  @@unique([siteId, orderNumber])
  @@index([clientId])
  @@index([siteId, status])
  @@index([siteId, fulfillmentExportedAt])
  @@index([siteId, printLabHandoffAt])
  @@index([customerEmail])
}

model GiftCardRedemption {
  id           String    @id @default(cuid())
  giftCardId   String
  giftCard     GiftCard  @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountCents  Int
  currency     String    @default("USD")
  codeSnapshot String
  restoredAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([giftCardId])
  @@index([orderId])
  @@index([restoredAt])
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  issuedGiftCard GiftCard?       @relation("GiftCardSaleOrderItem")
  name           String
  sku            String?
  quantity       Int             @default(1)
  unitPriceCents Int
  lineTotalCents Int
  giftCardRecipientName String    @default("")
  giftCardRecipientEmail String   @default("")
  giftCardMessage String          @default("")
  createdAt      DateTime        @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Payment {
  id                      String          @id @default(cuid())
  orderId                 String
  order                   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider                PaymentProvider
  status                  PaymentStatus   @default(PENDING)
  amountCents             Int
  refundedCents           Int             @default(0)
  currency                String          @default("USD")
  externalPaymentId       String?
  externalCheckoutSession String?
  hostedReceiptUrl        String?
  rawSummary              Json            @default("{}")
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  @@index([orderId])
  @@index([provider])
  @@index([status])
}

model PaymentGatewayCredential {
  id                    String                         @id @default(cuid())
  siteId                String
  site                  Site                           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  provider              PaymentProvider
  status                PaymentGatewayConnectionStatus @default(DISCONNECTED)
  externalAccountId     String                         @default("")
  merchantId            String                         @default("")
  displayName           String                         @default("")
  encryptedAccessToken  String                         @default("")
  encryptedRefreshToken String                         @default("")
  encryptedSecretKey    String                         @default("")
  encryptedWebhookSecret String                        @default("")
  webhookSecretHint     String                         @default("")
  supportedWallets      Json                           @default("[]")
  metadata              Json                           @default("{}")
  connectedAt           DateTime?
  expiresAt             DateTime?
  lastVerifiedAt        DateTime?
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt

  @@unique([siteId, provider])
  @@index([siteId, status])
  @@index([provider, status])
}

model StripeWebhookEvent {
  id          String                   @id @default(cuid())
  eventId     String
  type        String
  status      StripeWebhookEventStatus @default(PROCESSING)
  livemode    Boolean                  @default(false)
  summary     Json                     @default("{}")
  error       String                   @default("")
  processedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([eventId])
  @@index([status])
  @@index([type])
}

model SquareWebhookEvent {
  id          String                   @id @default(cuid())
  eventId     String
  merchantId  String                   @default("")
  type        String
  status      SquareWebhookEventStatus @default(PROCESSING)
  summary     Json                     @default("{}")
  error       String                   @default("")
  processedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([eventId])
  @@index([status])
  @@index([type])
  @@index([merchantId])
}

model PayPalWebhookEvent {
  id          String                   @id @default(cuid())
  eventId     String
  type        String
  status      PayPalWebhookEventStatus @default(PROCESSING)
  summary     Json                     @default("{}")
  error       String                   @default("")
  processedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@unique([eventId])
  @@index([status])
  @@index([type])
}
