// Module installation/deployment state. Part of the merged Prisma schema (prismaSchemaFolder).
// One ModuleInstallation row per installed module records install/enable/visibility/beta state and
// per-module config, replacing the single SiteSettings.enabledModules JSON array as the richer source
// of deployment truth.

enum AdminModuleNavigationCategory {
  PRIMARY
  WEBSITE
  MARKETING
  FINANCE
  MORE
}

// A user's durable admin-sidebar layout. Module manifests supply the initial category and registry
// order; after initialization these rows are the source of truth for category membership and order.
model AdminModuleNavigationItem {
  id        String                        @id @default(cuid())
  userId    String
  user      AdminUser                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String
  category  AdminModuleNavigationCategory
  sortOrder Int
  createdAt DateTime                      @default(now())
  updatedAt DateTime                      @updatedAt

  @@unique([userId, moduleId])
  @@index([userId, category, sortOrder])
}

model ModuleInstallation {
  id              String          @id @default(cuid())
  siteId          String
  site            Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  moduleId        String
  installed       Boolean         @default(true)
  enabled         Boolean         @default(false)
  visibleToPublic Boolean         @default(false)
  beta            Boolean         @default(false)
  configuredAt    DateTime?
  settings        Json            @default("{}")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  moduleSettings  ModuleSetting[]

  @@unique([siteId, moduleId])
  @@index([siteId, enabled])
}

model ModuleSetting {
  id           String             @id @default(cuid())
  siteId       String
  moduleId     String
  key          String
  value        Json
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  installation ModuleInstallation @relation(fields: [siteId, moduleId], references: [siteId, moduleId], onDelete: Cascade)

  @@unique([siteId, moduleId, key])
  @@index([siteId, moduleId])
}
