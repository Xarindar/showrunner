// Forms module models and enums.

enum FormStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum FormFieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  SELECT
  CHECKBOX
  RADIO
  DATE
  SIGNATURE
  FILE
  HIDDEN
}

enum FormFieldRole {
  NONE
  SUBMITTER_NAME
  SUBMITTER_EMAIL
}

enum FormDestination {
  STANDALONE_LEAD
  CLIENT
  BOOKING
  ORDER
  GALLERY
  INQUIRY
}

enum FormAttachmentTargetType {
  BOOKING
  ORDER
  GALLERY
}

enum FormSignatureCaptureType {
  TYPED
  DRAWN
}

model Form {
  id                String           @id @default(cuid())
  siteId            String
  site              Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  slug              String           @default(cuid())
  name              String
  description       String           @default("")
  status            FormStatus       @default(DRAFT)
  destination       FormDestination  @default(STANDALONE_LEAD)
  enableSteps       Boolean          @default(false)
  submitButtonLabel String           @default("Submit")
  successMessage    String           @default("Thanks. Your form was submitted.")
  notificationEmail String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  fields            FormField[]
  submissions       FormSubmission[]
  attachments       FormAttachment[]
  signatures        FormSignature[]

  @@unique([siteId, slug])
  @@index([siteId, status])
  @@index([destination])
}

model FormField {
  id          String        @id @default(cuid())
  formId      String
  form        Form          @relation(fields: [formId], references: [id], onDelete: Cascade)
  label       String
  type        FormFieldType
  fieldRole   FormFieldRole @default(NONE)
  placeholder String        @default("")
  helpText    String        @default("")
  options     Json          @default("[]")
  conditionalLogic Json          @default("{}")
  validationRules Json          @default("{}")
  isRequired  Boolean       @default(false)
  isHidden    Boolean       @default(false)
  pageNumber  Int           @default(1)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  signatures  FormSignature[]

  @@index([formId])
  @@index([type])
  @@index([fieldRole])
}

model FormSubmission {
  id               String          @id @default(cuid())
  formId           String
  form             Form            @relation(fields: [formId], references: [id], onDelete: Cascade)
  formAttachmentId String?
  formAttachment   FormAttachment? @relation(fields: [formAttachmentId], references: [id], onDelete: SetNull)
  clientId         String?
  client           Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  submitterName    String          @default("")
  submitterEmail   String          @default("")
  data             Json            @default("{}")
  metadata         Json            @default("{}")
  createdAt        DateTime        @default(now())
  signatures       FormSignature[]

  @@index([formId])
  @@index([formAttachmentId])
  @@index([clientId])
  @@index([submitterEmail])
}

model FormSignature {
  id                String                   @id @default(cuid())
  siteId            String
  site              Site                     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  formId            String
  form              Form                     @relation(fields: [formId], references: [id], onDelete: Cascade)
  formFieldId       String
  formField         FormField                @relation(fields: [formFieldId], references: [id], onDelete: Restrict)
  formSubmissionId  String
  formSubmission    FormSubmission           @relation(fields: [formSubmissionId], references: [id], onDelete: Cascade)
  captureType       FormSignatureCaptureType
  capturedSignature String
  signerName        String
  signerEmail       String                   @default("")
  consentStatement  String
  ipAddress         String                   @default("")
  userAgent         String                   @default("")
  signedAt          DateTime                 @default(now())
  createdAt         DateTime                 @default(now())

  @@unique([formSubmissionId, formFieldId])
  @@index([siteId, formId])
  @@index([formFieldId])
  @@index([signerEmail])
  @@index([signedAt])
}

model FormAttachment {
  id          String                   @id @default(cuid())
  siteId      String
  site        Site                     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  formId      String
  form        Form                     @relation(fields: [formId], references: [id], onDelete: Cascade)
  targetType  FormAttachmentTargetType
  targetId    String
  isRequired  Boolean                  @default(false)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  submissions FormSubmission[]

  @@unique([formId, targetType, targetId])
  @@index([siteId, targetType, targetId])
  @@index([formId])
  @@index([isRequired])
}
