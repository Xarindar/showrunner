DATABASE_URL="postgresql://postgres:postgres@localhost:5432/showrunner"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Build-time module selection for per-client deployments. Comma-separated module ids to include in
# this build (e.g. "dashboard,clients,scheduling,forms,billing"). Modules outside this list drop out
# of the registry entirely: no sidebar entry, no route, no enablement. Required platform modules are
# always included. Leave blank to ship every module.
MODULE_INCL=""

# Internal Client Deployments module. Create a GitHub OAuth app with the callback:
# NEXT_PUBLIC_APP_URL + /api/deployments/github/callback
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""
DEPLOYMENT_TEMPLATE_REPOSITORY="your-org/showrunner-template"
# Optional override for signed OAuth state. Defaults to AUTH_SECRET.
DEPLOYMENT_STATE_SECRET=""

# Local dev convenience only. Override before deploy.
ADMIN_EMAIL="admin"
ADMIN_PASSWORD="admin"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Bookings <bookings@example.com>"
SMTP_MAX_CONNECTIONS="3"
SMTP_MAX_MESSAGES="100"
SMTP_CONNECTION_TIMEOUT_MS="10000"
SMTP_SOCKET_TIMEOUT_MS="20000"

EMAIL_WORKER_SECRET="replace-with-a-long-random-worker-secret"
EMAIL_WORKER_LIMIT="50"
EMAIL_PROVIDER_WEBHOOK_SECRET="replace-with-a-long-random-webhook-secret"

# Payments are bring-your-own-credentials: the owner of each deployment pastes their own Stripe /
# Square / PayPal keys in Settings -> Payments and creates the webhooks there. Those secrets are stored
# ENCRYPTED in this database — no provider API keys belong in env. The only required payment env var is
# the encryption key below, which protects the stored credentials at rest. Make it long and random.
PAYMENT_CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-payment-credential-secret"
# Optional: pins Square's REST API version. Safe to leave as-is.
SQUARE_API_VERSION="2026-05-20"
# Optional override. Defaults to NEXT_PUBLIC_APP_URL + /api/webhooks/square (must match the URL used in
# your Square webhook subscription, which is part of the signature Square sends).
SQUARE_WEBHOOK_NOTIFICATION_URL=""

GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
# Optional override. Defaults to NEXT_PUBLIC_APP_URL + /api/scheduling/google-calendar/connect/callback.
GOOGLE_CALENDAR_REDIRECT_URI=""
SCHEDULING_CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-scheduling-credential-secret"

MEDIA_DRIVER="repo"
MEDIA_ASSET_DIR=".media-assets"
MEDIA_URL_SIGNING_SECRET="replace-with-a-long-random-media-url-secret"
MEDIA_VIRUS_SCAN_MODE="optional"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_IMAGES_API_TOKEN=""
CLOUDFLARE_IMAGES_ACCOUNT_HASH=""
