DATABASE_URL="postgresql://postgres:postgres@localhost:5432/showrunner"
AUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Build-time module selection for per-client deployments. Comma-separated module ids to exclude from
# this build (e.g. "products,billing,automation"). Excluded modules drop out of the registry entirely:
# no sidebar entry, no route, no enablement. Required platform modules (settings, dashboard, help)
# cannot be excluded. Leave blank to ship every module.
NEXT_PUBLIC_SHOWRUNNER_DISABLED_MODULES=""

# Local dev convenience only. Override before deploy.
ADMIN_EMAIL="admin"
ADMIN_PASSWORD="admin"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Bookings <bookings@example.com>"
SMTP_MAX_CONNECTIONS="3"
SMTP_MAX_MESSAGES="100"
SMTP_CONNECTION_TIMEOUT_MS="10000"
SMTP_SOCKET_TIMEOUT_MS="20000"

EMAIL_WORKER_SECRET="replace-with-a-long-random-worker-secret"
EMAIL_WORKER_LIMIT="50"
EMAIL_PROVIDER_WEBHOOK_SECRET="replace-with-a-long-random-webhook-secret"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""
# Optional override. Defaults to NEXT_PUBLIC_APP_URL + /api/payments/stripe/connect/callback.
STRIPE_CONNECT_REDIRECT_URI=""
SQUARE_ENVIRONMENT="sandbox"
SQUARE_APPLICATION_ID=""
SQUARE_APPLICATION_SECRET=""
SQUARE_WEBHOOK_SIGNATURE_KEY=""
# Optional override. Defaults to NEXT_PUBLIC_APP_URL + /api/payments/square/connect/callback.
SQUARE_CONNECT_REDIRECT_URI=""
# Optional override. Defaults to NEXT_PUBLIC_APP_URL + /api/webhooks/square.
SQUARE_WEBHOOK_NOTIFICATION_URL=""
SQUARE_API_VERSION="2026-05-20"
PAYMENT_CREDENTIAL_ENCRYPTION_KEY="replace-with-a-long-random-payment-credential-secret"

MEDIA_DRIVER="repo"
MEDIA_URL_SIGNING_SECRET="replace-with-a-long-random-media-url-secret"
MEDIA_VIRUS_SCAN_MODE="optional"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_IMAGES_API_TOKEN=""
CLOUDFLARE_IMAGES_ACCOUNT_HASH=""
